{
    "name":  "@x-clone/timeline-service",
    "version":  "0.0.0",
    "private":  true,
    "type":  "module",
    "scripts":  {
                    "dev":  "tsx watch --clear-screen=false src/server.ts",
                    "build":  "tsc --project tsconfig.build.json \u0026\u0026 tsc-alias --project tsconfig.build.json",
                    "start":  "node dist/server.js",
                    "db:generate":  "drizzle-kit generate",
                    "db:migrate":  "drizzle-kit migrate",
                    "lint":  "eslint . --max-warnings 0",
                    "check-types":  "tsc --project tsconfig.json --noEmit",
                    "test":  "vitest run"
                },
    "dependencies":  {
                         "@fastify/cors":  "^11.2.0",
                         "@repo/contracts":  "*",
                         "drizzle-orm":  "^0.45.2",
                         "fastify":  "^5.8.5",
                         "fastify-plugin":  "^6.0.0",
                         "postgres":  "^3.4.9",
                         "zod":  "^4.4.3"
                     },
    "devDependencies":  {
                            "@repo/eslint-config":  "*",
                            "@repo/typescript-config":  "*",
                            "@types/node":  "^25.9.2",
                            "eslint":  "^9.39.1",
                            "tsc-alias":  "^1.8.17",
                            "tsx":  "^4.22.4",
                            "typescript":  "5.9.2",
                            "vitest":  "^4.1.8",
                            "drizzle-kit":  "^0.31.10",
                            "pino-pretty":  "^13.1.3",
                            "vite":  "^8.0.16"
                        }
}
